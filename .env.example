# ---------------------------------------------------------------------------
# hermes-adapter — example environment
# Copy to .env and edit for your deployment.
# ---------------------------------------------------------------------------

# Workspace root — where repos live
HERMES_WORKSPACE_DIR=/workspaces

# Workspace HTTP API
HERMES_ADAPTER_HOST=0.0.0.0
HERMES_ADAPTER_PORT=8766

# A2A server
A2A_HOST=0.0.0.0
A2A_PORT=9000
# A2A_KEY=change-me-to-a-long-random-string
# A2A_PUBLIC_URL=https://a2a.example.com

# Agent Card
AGENT_NAME=hermes-agent
AGENT_DESCRIPTION=Hermes agent exposed via A2A
# AGENT_SKILLS=code,research,ops
# AGENT_MODEL=claude-opus-4-6

# Restrict toolsets for sandboxed A2A deployments (comma-separated)
# A2A_TOOLSETS=hermes-acp
